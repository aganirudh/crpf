# ─── PRAMAAN environment ───────────────────────────────────────────────────
# Copy this to .env and fill in. Never commit .env.

# ─── Application ───────────────────────────────────────────────────────────
PRAMAAN_ENV=dev
PRAMAAN_LOG_LEVEL=INFO
PRAMAAN_API_HOST=0.0.0.0
PRAMAAN_API_PORT=8000
PRAMAAN_FRONTEND_ORIGIN=http://localhost:3000

# ─── Postgres (matches infra/docker-compose.yml) ───────────────────────────
# Default compose maps Postgres to host port 5433 (avoids conflict with Windows
# services bound to 5432). If you remap compose back to "5432:5432", use 5432 here.
PRAMAAN_DB_URL=postgresql+psycopg://pramaan:pramaan@localhost:5433/pramaan

# ─── Object storage (MinIO, matches infra/docker-compose.yml) ──────────────
PRAMAAN_S3_ENDPOINT=http://localhost:9000
PRAMAAN_S3_ACCESS_KEY=pramaan
PRAMAAN_S3_SECRET_KEY=pramaanpramaan
PRAMAAN_S3_BUCKET=pramaan
PRAMAAN_S3_REGION=us-east-1
PRAMAAN_S3_USE_SSL=false

# ─── Vector store (Qdrant, matches infra/docker-compose.yml) ───────────────
PRAMAAN_QDRANT_URL=http://localhost:6333

# ─── OPA sidecar (matches infra/docker-compose.yml) ────────────────────────
PRAMAAN_OPA_URL=http://localhost:8181

# ─── LLM provider (OpenAI-compatible) ──────────────────────────────────────
# Pick ONE provider. The client speaks the OpenAI Chat Completions schema, so
# any OpenAI-compatible endpoint works:
#
#   • OpenAI         → https://api.openai.com/v1
#   • OpenRouter     → https://openrouter.ai/api/v1   (open-weights via key)
#   • Groq           → https://api.groq.com/openai/v1 (fast Llama inference)
#   • Together.ai    → https://api.together.xyz/v1
#   • Fireworks.ai   → https://api.fireworks.ai/inference/v1
#   • Local Ollama   → http://localhost:11434/v1      (no key needed)
#   • Colab vLLM     → https://<your-ngrok>.ngrok-free.app/v1
#
# Recommended default for free / cheap open-weights: OpenRouter

PRAMAAN_GEMINI_API_KEY=AIzaSyB-Ig6xNSdjIqtIO62X4l14vP0Z-QBR6cs
PRAMAAN_GEMINI_MODEL=gemini-3-flash-preview

PRAMAAN_LLM_PROVIDER=openrouter
PRAMAAN_LLM_BASE_URL=https://openrouter.ai/api/v1
# Real key from your provider. Values containing REPLACE_ME / changeme / etc. are treated as
# placeholders → mock LLM (offline demo). Leave blank for the same behaviour.
PRAMAAN_LLM_API_KEY=sk-or-v1-REPLACE_ME

# Models — pick open-weights to match the sovereign-deploy story.
# OpenRouter examples:
#   meta-llama/llama-3.1-70b-instruct
#   qwen/qwen-2.5-72b-instruct
#   mistralai/mixtral-8x22b-instruct
PRAMAAN_LLM_EXTRACTOR_MODEL=meta-llama/llama-3.1-70b-instruct
PRAMAAN_LLM_SKEPTIC_MODEL=qwen/qwen-2.5-72b-instruct
PRAMAAN_LLM_VLM_MODEL=qwen/qwen-2.5-vl-72b-instruct

# Determinism
PRAMAAN_LLM_TEMPERATURE=0
PRAMAAN_LLM_SEED=42
PRAMAAN_LLM_MAX_TOKENS=4096
PRAMAAN_LLM_TIMEOUT_S=120

# Set to 0 if your gateway returns 400 on unsupported `seed` (rare).
PRAMAAN_LLM_SEND_SEED=1

# Optional override for OpenRouter's HTTP-Referer header (defaults to PRAMAAN_FRONTEND_ORIGIN).
# PRAMAAN_OPENROUTER_HTTP_REFERER=http://localhost:3000

# Mock mode — set to 1 to bypass the LLM and use a deterministic stub
# (useful for offline development and CI)
PRAMAAN_LLM_MOCK=0

# ─── OCR ───────────────────────────────────────────────────────────────────
# Path to Tesseract executable (Windows: install from
# https://github.com/UB-Mannheim/tesseract/wiki ; default install path below)
PRAMAAN_TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe

# Whether to enable PaddleOCR (heavier; can be slow to install on Windows)
PRAMAAN_USE_PADDLEOCR=0

# ─── Audit ledger ──────────────────────────────────────────────────────────
# In dev we use a SoftHSM-equivalent file-based key. In prod this swaps to
# YubiHSM / CloudHSM via PKCS#11.
PRAMAAN_SIGNING_KEY_PATH=./storage/keys/signing_key.pem
PRAMAAN_SIGNING_KEY_ID=pramaan-dev-2026

# ─── Auth (mock OIDC for dev) ──────────────────────────────────────────────
PRAMAAN_AUTH_MODE=mock
PRAMAAN_MOCK_OFFICER_ID=officer:abc@crpf.gov.in
PRAMAAN_MOCK_OFFICER_NAME=Inspector A. B. Singh
